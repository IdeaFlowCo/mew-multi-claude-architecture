# Mew MCP Configuration
# Copy this file to .env and fill in your actual values.
# DO NOT COMMIT THE .env FILE.

BASE_URL="https://mew-edge.ideaflow.app/api"
BASE_NODE_URL="https://mew-edge.ideaflow.app/"
AUTH0_DOMAIN="your-auth0-domain.us.auth0.com"
AUTH0_CLIENT_ID="your-auth0-client-id"
AUTH0_CLIENT_SECRET="your-auth0-client-secret"
AUTH0_AUDIENCE="https://your-auth0-domain.us.auth0.com/api/v2/"
CURRENT_USER_ID="your-user-id"

# Optional: Port for the MCP server to listen on
# PORT=8080

# Here's how to manually extract the user ID from the URL in plain English:
#     1.    Take the full URL that looks like it ends in something like .../user-root-id-[some-id].
#     2.    Find the last part of the URL path (everything after the last /).